# ─────────────────────────────────────────────────────────────────────────────
# Controle de Ativos — Backend · Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o arquivo .env no repositório.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
#
# No Vercel (cloud) — use a string SRV padrão do Atlas:
#   MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/controle-ativos?retryWrites=true&w=majority
#
# Na rede corporativa Moby (DNS bloqueia SRV) — use conexão direta com os 3 shards:
#   MONGODB_URI=mongodb://<usuario>:<senha>@<shard-00>.mongodb.net:27017,<shard-01>.mongodb.net:27017,<shard-02>.mongodb.net:27017/controle-ativos?ssl=true&authSource=admin&retryWrites=true&w=majority&appName=<appName>
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/controle-ativos

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere um secret com: node -e "require('crypto').randomBytes(64).toString('base64')"
JWT_SECRET=troque-por-uma-chave-secreta-longa-e-aleatoria

# ── Servidor (apenas para execução local) ────────────────────────────────────
PORT=3001

# ── CORS — URL do frontend ────────────────────────────────────────────────────
# Local:      http://localhost:3000
# Produção:   https://controle-ativos-frontend.vercel.app  (URL real após deploy)
FRONTEND_URL=http://localhost:3000

# ── E-mail para alertas (opcional — não implementado no MVP) ──────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-de-app
# SMTP_FROM="Controle de Ativos <noreply@mobyweb.com.br>"
